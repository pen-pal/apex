#!/bin/sh
# Pre-push gate. Enable once with:  git config core.hooksPath .githooks
# 1) anti-slop must find no ERRORs.
# 2) if this push updates the multi-language code examples, they must still compile and print their expected values.
# Override either with 'git push --no-verify'.

command -v node >/dev/null 2>&1 || { printf '%s\n' "pre-push: node not on PATH; skipping (CI still enforces)."; exit 0; }

node scripts/anti-slop.mjs || {
  printf '\n%s\n' "push blocked: fix the anti-slop ERRORs above (or 'git push --no-verify' to override)."
  exit 1
}

# Decide whether to run the (slower) multi-language verify. git feeds each ref being pushed on stdin as
# "<local ref> <local sha> <remote ref> <remote sha>"; the remote sha is authoritative (not a stale tracking ref), so
# diffing it against the local sha is exactly what this push adds. verify:code itself skips any absent toolchain, so it
# never false-blocks a machine without go/rust/gcc.
NULL=0000000000000000000000000000000000000000
touched_examples=0
while read -r _local_ref local_sha _remote_ref remote_sha; do
  [ "$local_sha" = "$NULL" ] && continue                       # branch deletion — nothing to check
  if [ "$remote_sha" = "$NULL" ]; then                          # new branch: compare to where it forked from main
    range=$(git merge-base "$local_sha" origin/main 2>/dev/null)
    [ -n "$range" ] || { touched_examples=1; continue; }        # can't tell → verify to be safe
    range="$range $local_sha"
  else
    range="$remote_sha $local_sha"
  fi
  git diff --name-only $range 2>/dev/null | grep -q 'langSamples' && touched_examples=1
done

if [ "$touched_examples" = 1 ]; then
  printf '%s\n' "pre-push: code examples changed — verifying they compile and print their expected values…"
  node scripts/verify-code-examples.mjs || {
    printf '\n%s\n' "push blocked: a code example failed 'npm run verify:code' (or 'git push --no-verify' to override)."
    exit 1
  }
fi

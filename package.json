{
  "name": "apex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A live, interactive way to see how computers actually work \u2014 470 tested visualizations across networking, cryptography, distributed systems, databases, algorithms, hardware, and OS internals. Real bytes, real checksums, real crypto.",
  "homepage": "https://pen-pal.github.io/apex",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "demo": "tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "stats": "node scripts/stats.mjs",
    "stats:write": "node scripts/stats.mjs --write",
    "lint:slop": "node scripts/anti-slop.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vitest": "^2.0.3"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
